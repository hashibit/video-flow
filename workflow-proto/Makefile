.PHONY: proto clean

PROTO_DIR  := src
OUT_DIR    := gen-python/src/workflow_proto

# Regenerate Python gRPC stubs from all .proto files.
proto:
	python -m grpc_tools.protoc \
		-I$(PROTO_DIR) \
		--python_out=$(OUT_DIR) \
		--grpc_python_out=$(OUT_DIR) \
		$(PROTO_DIR)/*.proto
	@# Fix absolute imports generated by protoc (relative package path)
	@find $(OUT_DIR) -name "*_pb2_grpc.py" -exec \
		sed -i '' 's/^import \([a-z_]*\)_pb2 /from workflow_proto import \1_pb2 #noqa /g' {} \;
	@echo "Stubs regenerated in $(OUT_DIR)"

clean:
	find $(OUT_DIR) -name "*_pb2*.py" -delete
	@echo "Cleaned generated stubs"
