# workflow-ai environment variables
# Copy to .env and adjust as needed.

# Listen ports for each service
WORKFLOW_AI_ASR_ENDPOINT=0.0.0.0:50100
WORKFLOW_AI_DETECTION_ENDPOINT=0.0.0.0:50101
WORKFLOW_AI_FACE_FEATURE_ENDPOINT=0.0.0.0:50102
WORKFLOW_AI_OCR_GENERAL_ENDPOINT=0.0.0.0:50103
WORKFLOW_AI_OCR_HANDWRITING_ENDPOINT=0.0.0.0:50104
WORKFLOW_AI_OCR_DOCUMENT_ENDPOINT=0.0.0.0:50105
WORKFLOW_AI_OCR_ID_CARD_ENDPOINT=0.0.0.0:50106

# Thread pool size per gRPC server
WORKFLOW_AI_MAX_WORKERS=4

# ASR model (FunASR model name or local path)
WORKFLOW_AI_ASR_MODEL=paraformer-zh
WORKFLOW_AI_ASR_DEVICE=cpu

# Detection model path (InsightFace model root)
WORKFLOW_AI_DETECTION_MODEL_PATH=models/detection
WORKFLOW_AI_DETECTION_FACE_THRESHOLD=0.7
WORKFLOW_AI_DETECTION_BODY_THRESHOLD=0.7

# Face feature model path
WORKFLOW_AI_FACE_FEATURE_MODEL_PATH=models/face_feature

# OCR settings
WORKFLOW_AI_OCR_DEVICE=cpu
WORKFLOW_AI_OCR_LANG=ch

# Debug logging
WORKFLOW_AI_IS_DEBUG=false
