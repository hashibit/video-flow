# Environment variables for Workflow Manager

# Application
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./workflow_manager.db
DB_ECHO=false

# gRPC
GRPC_ENDPOINT=0.0.0.0:50051
GRPC_ENABLED=true

# External API
EXTERNAL_API_URL=
EXTERNAL_API_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
ENABLE_CURL_LOG=false
ENABLE_GORM_LOG=false

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=5
